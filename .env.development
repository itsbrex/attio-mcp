# Development environment configuration
# Uses brex-dev workspace for testing

# API Configuration
ATTIO_API_KEY=REPLACE_WITH_LOCAL_ATTIO_API_KEY
ATTIO_WORKSPACE_NAME=brex-dev
ATTIO_WORKSPACE_URL=https://app.attio.com/brex-dev

# Mapping Configuration
ATTIO_MAPPING_CONFIG=config/mappings/brex-dev.json

# Environment Settings
NODE_ENV=development
LOG_LEVEL=info

# Test Settings
SKIP_INTEGRATION_TESTS=false
TEST_WORKSPACE=brex-dev
